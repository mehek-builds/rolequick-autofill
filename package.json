{
  "name": "litos-extension",
  "version": "0.4.4",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "node scripts/ensure-no-qa-token.mjs && wxt build",
    "build:firefox": "node scripts/ensure-no-qa-token.mjs && wxt build -b firefox",
    "build:qa": "wxt build",
    "zip": "node scripts/ensure-no-qa-token.mjs && wxt zip",
    "zip:firefox": "node scripts/ensure-no-qa-token.mjs && wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "compile": "tsc --noEmit",
    "preview": "node preview/mock-server.mjs & VITE_API_BASE=http://localhost:3001 vite --port 4700",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.43",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@wxt-dev/module-react": "^1.2.2",
    "autoprefixer": "^10.4.19",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vitest": "^4.1.10",
    "wxt": "^0.20.26"
  }
}
